@startuml c4_l2_containers_perfis
!include <C4/C4_Container>

title OKR Driven Execution — C4 Nível 2: Containers e Interações por Perfil

' ─── Atores ────────────────────────────────────────────────────────────────

Person(admin, "Admin", "Configura o sistema,\ngerencia usuários e ciclos.")
Person(manager, "Manager", "Gerencia OKRs do time\ne encerra ciclos.")
Person(colaborador, "Colaborador", "Realiza check-ins nos\nKey Results atribuídos.")

' ─── Containers ────────────────────────────────────────────────────────────

System_Boundary(okr, "OKR Driven Execution") {

    Container(frontend, "Frontend", "Next.js / TypeScript", "Dashboard executivo, vista por responsável,\ntimeline de progresso e formulário de check-in.")

    Container(api, "API", ".NET / C#", "Processa comandos (check-in, criação de OKR,\nencerramento de ciclo) e publica eventos de domínio.")

    ContainerDb(postgres, "Banco de Escrita", "PostgreSQL", "Armazena eventos de domínio e snapshots.\nFonte canônica de verdade (Event Sourcing).")

    ContainerDb(mongo, "Banco de Leitura", "MongoDB", "Projeções otimizadas para leitura:\ndashboard, timeline e relatórios de ciclo.")

    Container(broker, "Message Broker", "RabbitMQ", "Roteia eventos de domínio para handlers\nde alerta e geração de relatórios.")
}

' ─── Relacionamentos por perfil ────────────────────────────────────────────

' Admin
Rel(admin, frontend, "Gerencia usuários, configura\nciclos e consulta relatórios", "HTTPS")

' Manager
Rel(manager, frontend, "Cria OKRs, acompanha time\ne encerra ciclos", "HTTPS")

' Colaborador
Rel(colaborador, frontend, "Realiza check-ins e\nvisualiza seu progresso", "HTTPS")

' Internos
Rel(frontend, api, "Envia comandos e consulta dados", "REST / JSON")
Rel(api, postgres, "Persiste eventos de domínio", "SQL")
Rel(api, broker, "Publica eventos de domínio", "AMQP")
Rel(broker, mongo, "Event handlers atualizam projeções", "Interno")
Rel(frontend, mongo, "Consultas de leitura via API", "REST / JSON")

@enduml
