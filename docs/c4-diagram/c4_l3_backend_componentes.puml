@startuml c4_l3_backend_componentes
!include <C4/C4_Component>

title OKR Driven Execution - C4 Nivel 3: Componentes do Backend (.NET)

' Ator externo
Container_Ext(frontend, "Frontend", "Next.js / TypeScript", "Envia comandos e consultas via HTTP.")

' Boundary: API .NET
Container_Boundary(api, "API - .NET / C#") {

    Component(controllers, "Controllers", "ASP.NET Core", "Recebe requisicoes HTTP e roteia para Command Handlers ou Query Handlers.")

    Component(cmd_handlers, "Command Handlers", "MediatR", "Orquestra o caso de uso de escrita: valida entrada e aciona o agregado.")

    Component(aggregates, "Agregados", "Domain Model", "Processa comandos, aplica regras de negocio e emite eventos de dominio.")

    Component(event_store_repo, "Event Store Repository", ".NET / EF Core", "Persiste eventos de dominio e snapshots no PostgreSQL.")

    Component(event_publisher, "Event Publisher", "MassTransit", "Publica eventos de dominio no RabbitMQ apos persistencia.")

    Component(query_handlers, "Query Handlers", "MediatR", "Consulta projecoes otimizadas no MongoDB para retorno ao Frontend.")

    Component(consumers, "Event Consumers", "MassTransit", "Consome eventos do broker e despacha para os handlers adequados.")

    Component(projection_handlers, "Projection Handlers", ".NET", "Atualiza o modelo de leitura no MongoDB a partir dos eventos de dominio.")

    Component(alert_handlers, "Alert Handlers", ".NET", "Avalia regras de alerta: KR em risco por 2+ semanas ou 0% de progresso no mes.")
}

' Infraestrutura
ContainerDb(postgres, "PostgreSQL", "Event Store (Escrita)", "Fonte canonica de verdade. Armazena eventos de dominio e snapshots.")
ContainerDb(mongo, "MongoDB", "Read Model (Leitura)", "Projecoes otimizadas para dashboard, timeline e relatorios de ciclo.")
Container(rabbitmq, "RabbitMQ", "Message Broker", "Desacopla publishers de consumers. Garante entrega assincrona dos eventos.")

' Relacionamentos
Rel(frontend, controllers, "Requisicoes HTTP", "REST / JSON / HTTPS")

Rel(controllers, cmd_handlers, "Encaminha comandos")
Rel(controllers, query_handlers, "Encaminha consultas")

Rel(cmd_handlers, aggregates, "Executa caso de uso")
Rel(aggregates, event_store_repo, "Persiste eventos gerados")
Rel(aggregates, event_publisher, "Emite eventos de dominio")
Rel(event_store_repo, postgres, "INSERT eventos e snapshots", "SQL")
Rel(event_publisher, rabbitmq, "Publish eventos", "AMQP")

Rel(query_handlers, mongo, "Consulta projecoes", "MongoDB Driver")

Rel(rabbitmq, consumers, "Entrega eventos", "AMQP")
Rel(consumers, projection_handlers, "Aciona atualizacao de projecao")
Rel(consumers, alert_handlers, "Aciona avaliacao de alerta")
Rel(projection_handlers, mongo, "Upsert projecoes", "MongoDB Driver")

@enduml
